pythondef _char_ngram_overlap(a: str, b: str, n: int = 3) -> float:
    """Char n-gram Jaccard between two strings."""
    ngrams_a = {a[i:i+n] for i in range(len(a)-n+1)}
    ngrams_b = {b[i:i+n] for i in range(len(b)-n+1)}
    if not ngrams_a or not ngrams_b:
        return 0.0
    return len(ngrams_a & ngrams_b) / len(ngrams_a | ngrams_b)

def _is_duplicate(a: str, b: str, *, word_t: float = 0.8, ngram_t: float = 0.6) -> bool:
    """True если один из двух сигналов превышает порог."""
    return (
        _jaccard_similarity(a, b) >= word_t
        or _char_ngram_overlap(a, b) >= ngram_t
    )
